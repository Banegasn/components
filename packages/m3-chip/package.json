{
  "name": "@banegasn/m3-chip",
  "version": "1.0.3",
  "description": "Material Design 3 chip web component with expressive styling",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "images"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "prepack": "node ../../scripts/package-license.js prepare",
    "postpack": "node ../../scripts/package-license.js clean",
    "clean": "rm -rf dist",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../scripts/no-tests.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banegasn/components.git",
    "directory": "packages/m3-chip"
  },
  "keywords": [
    "m3",
    "material-design",
    "chip",
    "web-components",
    "components"
  ],
  "author": "banegasn",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}

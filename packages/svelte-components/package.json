{
  "name": "@banegasn/svelte-components",
  "version": "3.2.3",
  "private": true,
  "description": "Svelte components library",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./SvelteButton.svelte": {
      "types": "./dist/SvelteButton.svelte.d.ts",
      "svelte": "./dist/SvelteButton.svelte",
      "default": "./dist/SvelteButton.svelte"
    }
  },
  "files": [
    "dist",
    "README.md",
    "images"
  ],
  "scripts": {
    "build": "svelte-package -i src",
    "dev": "svelte-package -i src --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "node ../../scripts/no-tests.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banegasn/components.git",
    "directory": "packages/svelte-components"
  },
  "keywords": [
    "svelte",
    "components",
    "ui"
  ],
  "author": "banegasn",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "svelte": "~5.56.4"
  },
  "devDependencies": {
    "@sveltejs/package": "~2.5.8",
    "@sveltejs/vite-plugin-svelte": "~4.0.4",
    "svelte-check": "~4.7.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}

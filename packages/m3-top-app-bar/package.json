{
  "name": "@banegasn/m3-top-app-bar",
  "version": "1.0.0",
  "description": "Material Design 3 Top App Bar web component",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "test": "wtr --config ../../web-test-runner.config.mjs \"src/**/*.test.ts\"",
    "test:watch": "wtr --config ../../web-test-runner.config.mjs \"src/**/*.test.ts\" --watch",
    "prepack": "node ../../scripts/package-license.js prepare",
    "postpack": "node ../../scripts/package-license.js clean",
    "clean": "rm -rf dist",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banegasn/components.git",
    "directory": "packages/m3-top-app-bar"
  },
  "keywords": [
    "m3",
    "material-design",
    "top-app-bar",
    "app-bar",
    "web-components",
    "components"
  ],
  "author": "banegasn",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
